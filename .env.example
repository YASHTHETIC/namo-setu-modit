# =============================================================================
# Namo Setu + MODIT — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Backend (Railway) ──────────────────────────────────────────────────────

# Neon PostgreSQL (replace with your Neon connection string)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/app?sslmode=require

# Upstash Redis (replace with your Upstash REST URL)
REDIS_URL=redis://default:xxxx@xxx.upstash.io:6379

# JWT — generate a strong random secret (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=replace-with-64-char-random-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=https://namo-setu.vercel.app,https://modit.vercel.app

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# ─── Email (SMTP) ───────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ─── Payment (Stripe) ──────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Payment (Razorpay — alternative) ──────────────────────────────────────

RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx

# ─── Google Maps ────────────────────────────────────────────────────────────

GOOGLE_MAPS_API_KEY=AIzaSyxxx

# ─── AI (OpenAI / LangChain) ───────────────────────────────────────────────

OPENAI_API_KEY=sk-xxx
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ─── Cloudinary (File Upload) ──────────────────────────────────────────────

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=your-api-secret

# ─── Frontend URL ───────────────────────────────────────────────────────────

FRONTEND_URL=https://namo-setu.vercel.app

# ─── Namo Setu Frontend (Vercel) ───────────────────────────────────────────

NEXT_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app/api/v1

# ─── MODIT Frontend (Vercel) ───────────────────────────────────────────────

NEXT_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app/api/v1

# ─── Celery (optional) ─────────────────────────────────────────────────────

# CELERY_BROKER_URL=redis://...
# CELERY_RESULT_BACKEND=redis://...

# ─── Legacy / Docker-only ──────────────────────────────────────────────────

# CHROMA_DB_PATH=/data/chroma
# FAISS_INDEX_PATH=/data/faiss
