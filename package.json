{
  "name": "namo-setu-modit-monorepo",
  "private": true,
  "workspaces": [
    "apps/*/web",
    "packages/*"
  ],
  "scripts": {
    "dev:namo": "npm run dev --workspace @namo-setu/web",
    "dev:modit": "npm run dev --workspace @modit/web",
    "dev:backend": "python -m uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "pytest"
  }
}
